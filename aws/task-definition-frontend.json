{
    "family": "task-frontend",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::559011734298:role/LabRole",
    "taskRoleArn": "arn:aws:iam::559011734298:role/LabRole",
    "containerDefinitions": [
        {
            "name": "frontend",
            "image": "559011734298.dkr.ecr.us-east-1.amazonaws.com/devops3:latest",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 80,
                    "protocol": "tcp"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/task-frontend",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "frontend"
                }
            }
        }
    ]
}
