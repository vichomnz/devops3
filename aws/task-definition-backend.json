{
    "family": "task-backend",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::559011734298:role/LabRole",
    "taskRoleArn": "arn:aws:iam::559011734298:role/LabRole",
    "containerDefinitions": [
        {
            "name": "backend",
            "image": "559011734298.dkr.ecr.us-east-1.amazonaws.com/devops3back:latest",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 3000,
                    "protocol": "tcp"
                }
            ],
            "environment": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/task-backend",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "backend"
                }
            }
        }
    ]
}
